---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
---

<Layout>
	<section
		class="relative w-full h-[70vh] bg-bgprimary bg-cover bg-center bg-no-repeat flex items-center"
		style="background-image: url('/HeroDark2.jpg')"
	>
		<div class="absolute inset-0 bg-black/40"></div>

		<div class="relative hero-container">
			<h1
				class="text-secondary text-[24px] xs:text-[26px] sm:text-[28px] md:text-[32px] lg:text-[36px]"
			>
				Clean, modern websites for small businesses
			</h1>
			<h2
				class="text-secondary text-[18px] xs:text-[19px] sm:text-[20px] md:text-[21px] lg:text-[22px]"
			>
				Design, development, hosting — the whole package, built with
				care.
			</h2>
		</div>
	</section>

	<section class="bg-bgprimary text-primary py-24">
		<div class="content-container">
			<p class="leading-relaxed max-w-[80ch] mx-auto">
				I create clean, sustainable websites for small businesses — from
				local shops and independent professionals to tourism,
				hospitality, and service‑based businesses. You can choose a
				custom static site, a Shopify store, or a WordPress setup, with
				design, development, hosting, and email all taken care of.
			</p>

			<p class="mt-6 leading-relaxed max-w-[80ch] mx-auto">
				Existing sites can be redesigned to feel modern, responsive, and
				intuitive. You decide how much support you want — full
				management or full independence.
			</p>

			<p class="mt-6 leading-relaxed max-w-[80ch] mx-auto">
				The aim is to build an online presence that feels like a true
				expression of your business: something you’re proud to share,
				not a site you have to fight with. The focus is on calm,
				clarity, and sustainability, so your website supports your work
				instead of distracting from it.
			</p>

			<p class="mt-6 leading-relaxed max-w-[80ch] mx-auto">
				Allowing you focus on the work you love.
			</p>
		</div>
	</section>

	<section class="bg-bgsecondary py-24 pb-10">
		<div class="content-container grid md:grid-cols-2 gap-16 items-center">
			<!-- LEFT: Static mockup image -->
			<div class="flex justify-center mb-10">
				<a
					href="https://brechfaforest.com"
					target="_blank"
					rel="noopener noreferrer"
					class="block group"
				>
					<img
						src="/Screen2.png"
						alt="Brechfa Forest desktop and mobile mockup"
						class="w-full max-w-[700px] h-auto object-contain transition-transform duration-300 hover:scale-105"
					/>
				</a>
			</div>

			<!-- RIGHT: What I offer -->
			<div>
				<h2
					class="text-secondary text-[24px] sm:text-[28px] md:text-[32px] lg:text-[36px] font-heading mb-6"
				>
					What I offer
				</h2>

				<ul
					class="space-y-3 text-secondary text-[18px] sm:text-[20px] md:text-[21px] lg:text-[22px]"
				>
					<ul
						class="space-y-3 text-secondary text-[18px] sm:text-[20px] md:text-[21px] lg:text-[22px]"
					>
						<li class="flex items-start gap-3">
							<span class="mt-1">
								<svg
									class="w-5 h-5"
									viewBox="0 0 24 24"
									fill="none"
								>
									<rect
										x="3"
										y="4"
										width="18"
										height="12"
										rx="2"
										stroke="currentColor"
										stroke-width="1.6"></rect>
									<path
										d="M9 20h6"
										stroke="currentColor"
										stroke-width="1.6"
										stroke-linecap="round"></path>
								</svg>
							</span>
							<span>Web design &amp; development</span>
						</li>

						<li class="flex items-start gap-3">
							<span class="mt-1">
								<svg
									class="w-5 h-5"
									viewBox="0 0 24 24"
									fill="none"
								>
									<rect
										x="4"
										y="4"
										width="16"
										height="6"
										rx="1.5"
										stroke="currentColor"
										stroke-width="1.6"></rect>
									<rect
										x="4"
										y="14"
										width="16"
										height="6"
										rx="1.5"
										stroke="currentColor"
										stroke-width="1.6"></rect>
									<circle
										cx="8"
										cy="7"
										r="0.9"
										fill="currentColor"></circle>
									<circle
										cx="8"
										cy="17"
										r="0.9"
										fill="currentColor"></circle>
								</svg>
							</span>
							<span>Hosting setup (Infomaniak)</span>
						</li>

						<li class="flex items-start gap-3">
							<span class="mt-1">
								<svg
									class="w-5 h-5"
									viewBox="0 0 24 24"
									fill="none"
								>
									<rect
										x="3"
										y="5"
										width="18"
										height="14"
										rx="2"
										stroke="currentColor"
										stroke-width="1.6"></rect>
									<path
										d="M5 7.5L12 12L19 7.5"
										stroke="currentColor"
										stroke-width="1.6"
										stroke-linecap="round"></path>
								</svg>
							</span>
							<span>Email hosting</span>
						</li>

						<li class="flex items-start gap-3">
							<span class="mt-1">
								<svg
									class="w-5 h-5"
									viewBox="0 0 24 24"
									fill="none"
								>
									<path
										d="M12 4L4 8.5L12 13L20 8.5L12 4Z"
										stroke="currentColor"
										stroke-width="1.6"></path>
									<path
										d="M4 12.5L12 17L20 12.5"
										stroke="currentColor"
										stroke-width="1.6"></path>
								</svg>
							</span>
							<span>WordPress, Shopify, custom static sites</span>
						</li>

						<li class="flex items-start gap-3">
							<span class="mt-1">
								<svg
									class="w-5 h-5"
									viewBox="0 0 24 24"
									fill="none"
								>
									<path
