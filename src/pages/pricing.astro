---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- HERO -->
  <section
    class="relative w-full h-[70vh] bg-bgprimary bg-cover bg-center bg-no-repeat flex items-center"
    style="background-image: url('/HeroDark2.jpg')"
  >
    <div class="absolute inset-0 bg-black/40"></div>

    <div class="relative hero-container">
      <h1 class="text-secondary text-[32px] md:text-[40px] lg:text-[48px]">
        Pricing
      </h1>
      <h2 class="text-secondary text-[18px] md:text-[22px] lg:text-[24px] mt-2">
        Clear, simple starting points for every type of build
      </h2>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="bg-bgprimary pt-10">
    <div class="content-container">
      <!-- Pricing Tiles -->
      <ul class="mx-auto max-w-6xl space-y-20">
        <!-- Custom Builds -->
        <li
          class="p-6 rounded-lg text-primary leading-relaxed
         grid grid-cols-1 md:grid-cols-2 gap-6 items-center shadow-lg hover:shadow-xl
  hover:-translate-y-1
  transition-all duration-300 ease-out"
        >
          <!-- LEFT: Text content -->
          <div>
            <h2 class="text-4xl text-center mb-5">Custom Builds</h2>

            <ul class="space-y-1 py-5 pl-1 text-center mb-8">
              <li>Clean, lightweight build</li>
              <li>Fully custom layout</li>
              <li>Initial design planning</li>
              <li>Built with Astro, HTML, Tailwind</li>
              <li>Fast + accessible</li>
              <li>Email included</li>
              <li>30 days post‑launch support</li>
            </ul>

            <div class="text-sm text-center">
              Hosting + domain ownership:
              <span class="font-medium">£60/year+</span>
            </div>

            <div class="text-4xl mt-4 text-right pt-15">£500+</div>
          </div>

          <!-- RIGHT: Image -->
          <div class="flex justify-center md:justify-end">
            <img
              src="/ScreenE.png"
              alt="Custom build illustration"
              class="object-contain opacity-90 transition-transform duration-300 hover:scale-105"
            />
          </div>
        </li>

        <!-- Shopify Builds -->
        <li
          class="p-6 bg-bgsecondary text-secondary rounded-lg leading-relaxed
         grid grid-cols-1 md:grid-cols-2 gap-6 items-center shadow-lg hover:shadow-xl
  hover:-translate-y-1
  transition-all duration-300 ease-out"
        >
          <!-- LEFT: Text content -->
          <div>
            <h2 class="text-4xl text-center mb-5">Shopify Builds</h2>
            <ul class="space-y-1 py-5 pl-1 text-center mb-8">
              <li>Fast, mobile‑first store</li>
              <li>Product + collection setup</li>
              <li>Theme customisation</li>
              <li>Clean, lightweight structure</li>
              <li>Custom coding</li>
              <li>30 days post‑launch support</li>
            </ul>
            <div class="text-4xl mt-4 text-right pt-15">£1000+</div>
          </div>
          <!-- RIGHT: Image -->
          <div class="flex justify-center md:justify-end">
            <img
              src="/ScreenPC.png"
              alt="Custom build illustration"
              class="object-contain opacity-90 transition-transform duration-300 hover:scale-105"
            />
          </div>
        </li>

        <!-- WordPress Builds -->
        <li
          class="p-6 rounded-lg text-primary leading-relaxed
         grid grid-cols-1 md:grid-cols-2 gap-6 items-center shadow-lg hover:shadow-xl
  hover:-translate-y-1
  transition-all duration-300 ease-out"
        >
          <!-- LEFT: Text content -->
          <div>
            <h2 class="text-4xl text-center mb-5">WordPress Builds</h2>
            <ul class="space-y-1 py-5 pl-1 text-center mb-8">
              <li>Clean, modern theme</li>
              <li>Simplified, lightweight setup</li>
              <li>Reduced plugins for stability</li>
              <li>Easy content editing</li>
              <li>Fast + accessible</li>
              <li>Email included</li>
              <li>30 days post‑launch support</li>
            </ul>
            <div class="text-sm text-center">
              Hosting + domain ownership:
              <span class="font-medium">£60/year+</span>
            </div>
            <div class="text-4xl mt-4 text-right pt-15">£550+</div>
          </div>

          <!-- RIGHT: Image -->
          <div class="flex justify-center md:justify-end">
            <img
              src="/ScreenOT.png"
              alt="Custom build illustration"
              class="object-contain opacity-90 transition-transform duration-300 hover:scale-105"
            />
          </div>
        </li>

        <!-- Ongoing Support -->
        <li
          class="p-6 border border-primary/20 bg-bgsecondary text-secondary rounded-lg leading-relaxed
         grid grid-cols-1 md:grid-cols-2 gap-6 items-center shadow-lg hover:shadow-xl
  hover:-translate-y-1
  transition-all duration-300 ease-out"
        >
          <!-- LEFT: Text content -->
          <div>
            <h2 class="text-4xl text-center mb-5">
              Ongoing Support & Coaching
            </h2>
            <ul class="space-y-1 py-5 pl-1 text-center mb-8">
              <li>1:1 video call sessions</li>
              <li>Website coaching & training</li>
              <li>Help with updates & fixes</li>
              <li>Content changes & improvements</li>
              <li>Guidance on managing your site</li>
              <li>Flexible, book‑as‑needed support</li>
            </ul>
            <div class="text-4xl mt-4 text-right pt-15">£25/hr</div>
          </div>
          <!-- RIGHT: Image -->
          <div class="flex justify-center md:justify-end">
            <img
              src="/ScreenPC.png"
              alt="Custom build illustration"
              class="object-contain opacity-90 transition-transform duration-300 hover:scale-105"
            />
          </div>
        </li>
      </ul>
    </div>
  </section>

  <section class="bg-bgprimary p-10">
    <div class="content-container">
      <div
        class="mx-auto max-w-6xl grid grid-cols-1 md:grid-cols-[70%_30%] items-center gap-4"
      >
        <!-- LEFT: Text -->
        <p class="leading-relaxed py-6">
          Pricing varies depending on the size and complexity of the build, but
          these starting points give a clear sense of what to expect. If you'd
          like a more accurate idea tailored to your project, please get in
          touch.
        </p>

        <!-- RIGHT: Button -->
        <div class="flex md:justify-end justify-center">
          <a
            href="/contact"
            class="inline-block px-6 py-3 rounded-md bg-[#D7B7C4] text-bgprimary font-medium
                 hover:opacity-80 transition-opacity"
          >
            Contact me
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
