---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <section
        class="relative w-full h-[70vh] bg-bgsecondary bg-cover bg-center bg-no-repeat flex items-center"
        style="background-image: url('/HeroDark2.jpg')"
    >
	<div class="absolute inset-0 bg-black/40"></div>

        <div class="relative hero-container">
            <h1
                class="text-secondary text-[24px] xs:text-[26px] sm:text-[28px] md:text-[32px] lg:text-[36px]"
            >
                Privacy Policy
            </h1>
            <h2
                class="text-secondary text-[18px] xs:text-[19px] sm:text-[20px] md:text-[21px] lg:text-[22px]"
            >
                How your information is collected and used
            </h2>
        </div>
    </section>

    <section class="w-full bg-bgsecondary py-20">
  <div class="content-container py-10">
    <h2 class="text-4xl text-secondary py-10 text-center">We take your privacy seriously...</h2>

    <div class="max-w-prose mx-auto text-secondary leading-relaxed space-y-6 ">
      <p>
        This website collects personal information only when a visitor chooses to submit it through the contact form. This typically includes a name, an email address, and the message provided.
      </p>

      <p>
        The information is used solely to respond to the enquiry. It is not shared with third parties, and the website does not use analytics tools, tracking scripts, advertising cookies, or behavioural profiling technologies.
      </p>

      <p>
        All information is stored securely and retained only for as long as necessary to respond to the message. Visitors may request the removal of their details at any time by contacting the site owner directly.
      </p>

      <p>
        This website operates in accordance with UK GDPR and EU GDPR requirements. The policy is reviewed and updated whenever data practices change.
      </p>
    </div>
  </div>
</section>

</Layout>
